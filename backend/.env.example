# ─── サーバー設定 ────────────────────────────────────
DEBUG=True
PORT=8000

# ─── RunPod GPU サーバー（声優ボイス用）──────────────
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID
RUNPOD_API_KEY=your_runpod_api_key_here

# ─── フロントエンドURL（CORS用）─────────────────────
FRONTEND_URL=http://localhost:3000

# 追加の CORS 許可オリジン（カンマ区切りで複数指定可、ngrok等のデプロイURL）
# EXTRA_CORS_ORIGINS=https://your-app.ngrok-free.dev,https://your-domain.com

# ─── Google OAuth（YouTube転送用）───────────────────
# Google Cloud Console で取得したOAuthクライアントID・シークレット
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# OAuthコールバックURL（本番環境に合わせて変更）
GOOGLE_REDIRECT_URI=http://localhost:8000/youtube/callback
